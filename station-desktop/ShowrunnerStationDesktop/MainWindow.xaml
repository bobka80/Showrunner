<Window x:Class="Showrunner.Station.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Showrunner Station"
        Icon="app.ico"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0d0f12"
        PreviewKeyDown="Window_OnPreviewKeyDown">
  <Grid>
    <wv2:WebView2 x:Name="WebView" />
    <Border x:Name="Splash" Background="#0d0f12" Panel.ZIndex="10">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <ProgressBar IsIndeterminate="True" Width="46" Height="46" />
        <TextBlock Margin="0,18,0,0" Foreground="#e8eaed" FontSize="15" FontWeight="Bold"
                   HorizontalAlignment="Center">
          SHOWRUNNER<Run Foreground="#e11d48"> STATION</Run>
        </TextBlock>
        <TextBlock Margin="0,10,0,0" Foreground="#8a8f98" FontSize="11"
                   HorizontalAlignment="Center">STARTING…</TextBlock>
      </StackPanel>
    </Border>
    <TextBlock x:Name="StatusBar" VerticalAlignment="Bottom" Background="#CC111114"
               Foreground="#f97316" FontSize="11" Padding="8" TextWrapping="Wrap"
               Panel.ZIndex="20" Visibility="Collapsed" />
  </Grid>
</Window>
